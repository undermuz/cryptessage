# Copy to `.env` in this directory (or any path you pass to docker --env-file).
# Do not commit real `.env` files.
#
# Required
DEPLOYMENT_SECRET=change-me-to-match-client-baseurl-path-segment
# Required for POW_MODE=adaptive (default). Must differ from DEPLOYMENT_SECRET.
SESSION_HMAC_SECRET=change-me-server-only-random-secret

# Optional
PORT=3333
# CHALLENGE_DIFFICULTY_BITS=18
# INBOX_BEARER_TOKEN=
# SKIP_POW=false
# POW_MODE=adaptive
# POW_IDLE_MS_BEFORE_POW=1800000
# POW_MAX_RPS=5
# POW_MAX_RPM=350
# SESSION_MAX_TTL_MS=86400000
# OUTBOX_PAGE_SIZE=50
# CORS_ORIGIN=
